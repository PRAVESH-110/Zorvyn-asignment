PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/finance_dashboard
JWT_SECRET=secret_key
JWT_EXPIRES_IN=1d
TRUST_PROXY=1
# Optional API rate limit (express-rate-limit): max requests per IP per window
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# Behind a reverse proxy, set so client IP is correct: TRUST_PROXY=1